# Copy to .env for local dev:  cp .env.example .env
# On Render, set these in the dashboard (Environment) instead of a file.

PORT=3000
HOST=0.0.0.0

# Must match TAN_WEBHOOK_SECRET in the phone app (SmsReceiver.kt). Use a long random string.
TAN_WEBHOOK_SECRET=change_me_to_a_long_random_secret

# Local Redis. On Render, attach a Redis instance and it injects REDIS_URL automatically.
REDIS_URL=redis://127.0.0.1:6379

# TAN scraping / storage
TAN_LENGTH=6
TAN_TTL_SECONDS=300
TAN_DEDUPE_SECONDS=120

# Comma-separated CRDB sender IDs the server will accept TANs from.
ALLOWED_SENDERS=CRDB,CRDB-BANK,CRDB BANK,CRDBBANK

# ── Disburse worker (Playwright). Only needed where the worker RUNS, not on
#    the Render webhook. Keep these out of git (this file is the example only). ──
BANK_LOGIN_URL=https://omnichannels.crdbbank.co.tz/netteller-war/Login.xhtml
BANK_USERNAME=your_corporate_username
BANK_PASSWORD=your_password
BANK_FROM_ACCOUNT=10346845061
BANK_HEADLESS=true
WEBHOOK_BASE_URL=https://elegansky-crdb-disburser.onrender.com

# Safety rails (real money):
DISBURSE_DRY_RUN=true
DISBURSE_MAX_RECIPIENTS=200
DISBURSE_MAX_TOTAL_TZS=5000000
